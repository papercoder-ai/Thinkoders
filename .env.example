# =========================================================
# Unified Root Environment (Attendance + LeaveFlow)
# =========================================================

# --------------------
# Attendance (Next.js)
# --------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --------------------
# Integrations
# --------------------
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_whatsapp_webhook_verify_token
GEMINI_API_KEY=your_gemini_api_key

# --------------------
# Legacy LeaveFlow backend (optional, not required for unified runtime)
# --------------------
# LEAVEFLOW_API_URL=http://localhost:8000
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/leaveflow
SECRET_KEY=your_leaveflow_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
WHATSAPP_VERIFY_TOKEN=your_leaveflow_verify_token
WHATSAPP_PHONE_NUMBER_ID=your_leaveflow_phone_number_id
OPENROUTER_API_KEY=your_openrouter_api_key
AI_MODEL=meta-llama/llama-2-70b-chat:free
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
